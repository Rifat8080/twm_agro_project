<%= form_with(model: staff, local: true) do |form| %>
  <div class="field">
    <%= form.label :user_id %>
    <%= form.collection_select :user_id, User.all, :id, :email, prompt: "Select a User" %>
  </div>

  <div class="field">
    <%= form.label :organization_id %>
    <%= form.collection_select :organization_id, Organization.all, :id, :organization_name, prompt: "Select an Organization" %>
  </div>

  <div class="field">
    <%= form.label :roles %><br>
    <%= form.select :roles, ["admin", "manager", "editor", "viewer"], {}, multiple: true %>
  </div>

  <div class="actions">
    <%= form.submit %>
  </div>
<% end %>
